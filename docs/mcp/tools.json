{
  "version": "0.1.0",
  "server": "io.github.nni-hotel/demo-mcp",
  "tools": [
    {
      "name": "base64_encode",
      "description": "Encode UTF-8 text to Base64 (standard or URL-safe). Deterministic.",
      "rest_path": "/v1/tools/base64/encode",
      "rest_method": "POST",
      "openapi_operation_id": "base64Encode",
      "deterministic": true,
      "semantic_tags": ["encoding", "base64", "text", "utf8"]
    },
    {
      "name": "base64_decode",
      "description": "Decode Base64 to UTF-8 text. Not for binary.",
      "rest_path": "/v1/tools/base64/decode",
      "rest_method": "POST",
      "openapi_operation_id": "base64Decode",
      "deterministic": true,
      "semantic_tags": ["decoding", "base64", "text", "utf8"]
    }
  ]
}
